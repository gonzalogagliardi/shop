---
interface Props {
  name:      string;
  location:  string;
  rating:    number;
  text:      string;
  product?:  string;
}

const { name, location, rating, text, product } = Astro.props;
const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col relative overflow-hidden">
  <!-- Accent bar -->
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-nova-600 to-nova-400 opacity-0 group-hover:opacity-100"></div>

  <!-- Stars -->
  <div class="flex items-center gap-0.5 mb-4">
    {stars.map(filled => (
      <svg
        class={`w-5 h-5 ${filled ? 'text-amber-400' : 'text-gray-200'}`}
        fill="currentColor"
        viewBox="0 0 20 20"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <p class="font-body text-gray-700 text-sm leading-relaxed mb-6 flex-1">
    "{text}"
  </p>

  <!-- Author -->
  <div class="flex items-center gap-3">
    <div class="w-11 h-11 rounded-full bg-gradient-to-br from-nova-600 to-nova-800 flex items-center justify-center flex-shrink-0 shadow-sm">
      <span class="font-heading font-bold text-white text-base">{name.charAt(0)}</span>
    </div>
    <div>
      <p class="font-body font-bold text-gray-900 text-sm">{name}</p>
      <p class="font-body text-gray-400 text-xs mt-0.5">{location}</p>
    </div>
    {product && (
      <span class="ml-auto font-body text-xs text-nova-700 bg-nova-50 border border-nova-100 px-2.5 py-1 rounded-full font-medium flex-shrink-0">
        ✓ Compra verificada
      </span>
    )}
  </div>
</div>
