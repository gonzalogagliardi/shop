---
const year = new Date().getFullYear();

const links = [
  { label: 'Inicio',             href: '/' },
  { label: 'Cepillo quitapelos', href: '/cepillo' },
  { label: 'Juguete mascota',    href: '/juguete' },
  { label: 'Envíos',             href: '/envios' },
  { label: 'Políticas',          href: '/politicas' },
  { label: 'Contacto',           href: '/contacto' },
];

const paymentMethods = [
  {
    name: 'Visa',
    bg: '#1A1F71',
    content: `<svg viewBox="0 0 50 16" class="h-4 w-auto"><text x="0" y="13" font-family="Arial,sans-serif" font-weight="700" font-style="italic" font-size="15" fill="white" letter-spacing="1">VISA</text></svg>`,
  },
  {
    name: 'Mastercard',
    bg: '#252525',
    content: `<svg viewBox="0 0 38 24" class="h-5 w-auto"><circle cx="14" cy="12" r="8" fill="#EB001B"/><circle cx="24" cy="12" r="8" fill="#F79E1B"/><path d="M19 5.8a8 8 0 0 1 0 12.4A8 8 0 0 1 19 5.8z" fill="#FF5F00"/></svg>`,
  },
  {
    name: 'American Express',
    bg: '#007BC1',
    content: `<svg viewBox="0 0 60 18" class="h-3.5 w-auto"><text x="0" y="14" font-family="Arial,sans-serif" font-weight="800" font-size="13" fill="white" letter-spacing="1.5">AMEX</text></svg>`,
  },
  {
    name: 'Mercado Pago',
    bg: '#009EE3',
    content: `<svg viewBox="0 0 100 18" class="h-3 w-auto"><text x="0" y="14" font-family="Arial,sans-serif" font-weight="700" font-size="12" fill="white" letter-spacing="0.5">Mercado Pago</text></svg>`,
  },
  {
    name: 'Naranja',
    bg: '#F15A24',
    content: `<svg viewBox="0 0 72 18" class="h-3 w-auto"><text x="0" y="14" font-family="Arial,sans-serif" font-weight="700" font-size="13" fill="white" letter-spacing="0.5">naranja</text></svg>`,
  },
  {
    name: 'Cabal',
    bg: '#005F9E',
    content: `<svg viewBox="0 0 55 18" class="h-3 w-auto"><text x="0" y="14" font-family="Arial,sans-serif" font-weight="800" font-size="13" fill="white" letter-spacing="1">CABAL</text></svg>`,
  },
];
---

<footer class="bg-gray-950 text-gray-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-5">
          <div class="w-8 h-8 bg-nova-700 rounded-lg flex items-center justify-center">
            <span class="font-heading font-bold text-white text-sm">N</span>
          </div>
          <span class="font-heading font-bold text-xl text-white">NovaShop</span>
        </a>
        <p class="font-body text-sm leading-relaxed text-gray-500 max-w-xs">
          Productos prácticos para tu día a día. Envíos a todo el país con garantía de satisfacción.
        </p>
        <div class="flex items-center gap-3 mt-6">
          <!-- WhatsApp -->
          <a
            href="https://wa.me/5491112345678"
            target="_blank"
            rel="noopener"
            aria-label="WhatsApp"
            class="w-9 h-9 rounded-full bg-gray-800 hover:bg-green-600 flex items-center justify-center transition-colors"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.116 1.524 5.843L.057 23.9l6.194-1.443A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.667-.5-5.204-1.378l-.374-.222-3.868.9.937-3.768-.245-.392A9.967 9.967 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://instagram.com/novashop"
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="w-9 h-9 rounded-full bg-gray-800 hover:bg-pink-600 flex items-center justify-center transition-colors"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-heading font-bold text-white text-xs uppercase tracking-widest mb-5">Navegación</h3>
        <ul class="space-y-3">
          {links.map(link => (
            <li>
              <a href={link.href} class="font-body text-sm text-gray-500 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading font-bold text-white text-xs uppercase tracking-widest mb-5">Contacto</h3>
        <ul class="space-y-4">
          <li>
            <a href="https://wa.me/5491112345678" target="_blank" rel="noopener" class="flex items-center gap-3 group">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.116 1.524 5.843L.057 23.9l6.194-1.443A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.667-.5-5.204-1.378l-.374-.222-3.868.9.937-3.768-.245-.392A9.967 9.967 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
              <span class="font-body text-sm text-gray-500 group-hover:text-white transition-colors">+54 9 11 1234-5678</span>
            </a>
          </li>
          <li>
            <a href="mailto:contacto@novashop.com.ar" class="flex items-center gap-3 group">
              <svg class="w-4 h-4 text-nova-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              <span class="font-body text-sm text-gray-500 group-hover:text-white transition-colors">contacto@novashop.com.ar</span>
            </a>
          </li>
          <li>
            <a href="https://instagram.com/novashop" target="_blank" rel="noopener" class="flex items-center gap-3 group">
              <svg class="w-4 h-4 text-pink-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              <span class="font-body text-sm text-gray-500 group-hover:text-white transition-colors">@novashop</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- ── Medios de pago ── -->
    <div class="mt-12 pt-8 border-t border-gray-800">
      <p class="font-body text-xs text-gray-600 uppercase tracking-widest mb-5">Medios de pago aceptados</p>
      <div class="flex flex-wrap items-center gap-2">

        <!-- Visa -->
        <div class="h-8 w-14 bg-[#1A1F71] flex items-center justify-center border border-white/10" style="font-family: Arial, sans-serif;">
          <span class="text-white font-black italic text-sm tracking-tight">VISA</span>
        </div>

        <!-- Mastercard -->
        <div class="h-8 w-14 bg-[#1A1F71] flex items-center justify-center border border-white/10 bg-gray-900">
          <svg viewBox="0 0 42 26" class="h-5 w-auto">
            <circle cx="15" cy="13" r="9" fill="#EB001B"/>
            <circle cx="27" cy="13" r="9" fill="#F79E1B"/>
            <path d="M21 5.5a9 9 0 0 1 0 15A9 9 0 0 1 21 5.5z" fill="#FF5F00"/>
          </svg>
        </div>

        <!-- AMEX -->
        <div class="h-8 w-14 bg-[#007BC1] flex items-center justify-center border border-white/10" style="font-family: Arial, sans-serif;">
          <span class="text-white font-black text-xs tracking-widest">AMEX</span>
        </div>

        <!-- Mercado Pago -->
        <div class="h-8 px-3 bg-[#009EE3] flex items-center justify-center gap-1.5 border border-white/10">
          <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 20 20">
            <circle cx="10" cy="10" r="10" fill="white"/>
            <path d="M5 10.5l3 3 7-7" stroke="#009EE3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
          <span class="text-white font-bold text-xs whitespace-nowrap" style="font-family: Arial, sans-serif;">Mercado Pago</span>
        </div>

        <!-- Naranja -->
        <div class="h-8 w-14 bg-[#F15A24] flex items-center justify-center border border-white/10" style="font-family: Arial, sans-serif;">
          <span class="text-white font-bold text-xs tracking-wide">naranja</span>
        </div>

        <!-- Cabal -->
        <div class="h-8 w-16 bg-[#005F9E] flex items-center justify-center border border-white/10" style="font-family: Arial, sans-serif;">
          <span class="text-white font-black text-xs tracking-widest">CABAL</span>
        </div>

      </div>

      <!-- Security note -->
      <p class="font-body text-xs text-gray-700 mt-4 flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
        Tus pagos están protegidos con encriptación SSL de 256 bits
      </p>
    </div>

    <!-- ── Bottom bar ── -->
    <div class="mt-8 pt-6 border-t border-gray-800/60 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-gray-600">© {year} NovaShop. Todos los derechos reservados.</p>
      <div class="flex items-center gap-6">
        <a href="/politicas" class="font-body text-xs text-gray-600 hover:text-gray-300 transition-colors">Políticas</a>
        <a href="/envios"    class="font-body text-xs text-gray-600 hover:text-gray-300 transition-colors">Envíos</a>
      </div>
    </div>
  </div>
</footer>
