---
const nav = [
  { label: 'Inicio',          href: '/' },
  { label: 'Cepillo',         href: '/cepillo' },
  { label: 'Juguete mascota', href: '/juguete' },
  { label: 'Contacto',        href: '/contacto' },
];

const announcements = [
  {
    icon: `<svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`,
    text: 'Envío gratis a todo el país en compras mayores a $15.000',
  },
  {
    icon: `<svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>`,
    text: '+500 clientes satisfechos · Calificación 4.9 / 5',
  },
  {
    icon: `<svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
    text: 'Pago 100 % seguro con MercadoPago · Cuotas disponibles',
  },
  {
    icon: `<svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    text: 'Garantía de devolución de 30 días sin preguntas',
  },
];
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-shadow duration-300"
>

  <!-- ── Announcement bar ── -->
  <div class="bg-nova-700 h-9 flex items-center overflow-hidden">
    <div class="w-full flex items-center justify-center px-4 relative h-full">
      {announcements.map((item, i) => (
        <span
          class={`announcement-item absolute inset-0 flex items-center justify-center gap-2 font-body text-white text-xs font-medium tracking-wide transition-opacity duration-500 px-8 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
          data-index={i}
        >
          <span set:html={item.icon} />
          {item.text}
        </span>
      ))}
    </div>
  </div>

  <!-- ── Main nav ── -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-[68px]">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group flex-shrink-0">
          <div class="w-9 h-9 bg-nova-700 rounded flex items-center justify-center shadow-sm shadow-nova-700/30">
            <span class="font-heading font-extrabold text-white text-base leading-none">N</span>
          </div>
          <span class="font-heading font-extrabold text-xl tracking-tight text-gray-900 group-hover:text-nova-700 transition-colors">
            NovaShop
          </span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-7">
          {nav.map(item => (
            <a
              href={item.href}
              class="font-body font-medium text-sm text-gray-600 hover:text-nova-700 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-nova-700 after:transition-all hover:after:w-full"
            >
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Desktop CTA -->
        <a
          href="/cepillo"
          class="hidden md:inline-flex items-center gap-2 bg-nova-700 hover:bg-nova-800 active:scale-95 text-white font-body font-bold text-sm px-6 py-3 rounded-none transition-all duration-200 hover:shadow-lg hover:shadow-nova-700/30 hover:-translate-y-px"
        >
          Ver productos
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>

        <!-- Hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden p-2.5 rounded text-gray-600 hover:bg-gray-100 active:bg-gray-200 transition-colors"
          aria-label="Abrir menú"
        >
          <svg id="icon-open"  class="w-5 h-5"        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white shadow-lg">
    <nav class="px-4 py-4 flex flex-col gap-1">
      {nav.map(item => (
        <a
          href={item.href}
          class="font-body font-medium text-gray-700 hover:text-nova-700 hover:bg-nova-50 px-4 py-3.5 rounded-xl transition-colors text-base"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-3 border-t border-gray-100 mt-2">
        <a
          href="/cepillo"
          class="flex items-center justify-center gap-2 bg-nova-700 active:bg-nova-800 text-white font-body font-bold text-base px-5 py-4 rounded-none w-full transition-colors"
        >
          Ver productos
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Scroll-responsive shadow
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (window.scrollY > 12) {
      header?.classList.add('shadow-md', 'shadow-gray-200/60');
    } else {
      header?.classList.remove('shadow-md', 'shadow-gray-200/60');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconO  = document.getElementById('icon-open');
  const iconC  = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconO?.classList.toggle('hidden');
    iconC?.classList.toggle('hidden');
  });

  // Announcement carousel
  const items = Array.from(document.querySelectorAll<HTMLElement>('.announcement-item'));
  if (items.length > 1) {
    let current = 0;
    setInterval(() => {
      items[current].style.opacity = '0';
      current = (current + 1) % items.length;
      items[current].style.opacity = '1';
    }, 3500);
  }
</script>
