---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
---

<BaseLayout
  title="¡Gracias por tu compra! — NovaShop"
  description="Tu pedido fue confirmado. Te enviamos todos los detalles por email."
>
  <Header />

  <main class="pt-16 min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24">

      <!-- Status icon + heading (JS lo puede swapear para pending) -->
      <div class="text-center mb-16">
        <div id="status-icon" class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-8">
          <svg class="w-12 h-12 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h1 id="status-heading" class="font-heading font-extrabold text-gray-900 text-4xl sm:text-5xl mb-4">
          ¡Gracias por tu compra!
        </h1>
        <p id="status-body" class="font-body text-gray-500 text-xl max-w-lg mx-auto">
          Tu pedido fue confirmado y está en camino. Pronto vas a recibir tu producto.
        </p>
      </div>

      <!-- Cards -->
      <div class="space-y-6 mb-12">

        <!-- Shipping -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 bg-nova-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-nova-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="font-heading font-bold text-gray-900 text-xl mb-2">Información de envío</h2>
              <p class="font-body text-gray-600 text-sm leading-relaxed mb-4">
                Tu pedido será despachado en las próximas 24 a 48 horas hábiles.
                Recibirás un email con el número de seguimiento para rastrear tu envío en tiempo real.
              </p>
              <div class="bg-gray-50 rounded-xl p-4 flex items-center gap-2">
                <svg class="w-4 h-4 text-nova-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="font-body font-semibold text-gray-700 text-sm">Entrega estimada: 3 a 7 días hábiles</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Next steps -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <h2 class="font-heading font-bold text-gray-900 text-xl mb-6">¿Qué pasa ahora?</h2>
          <div class="space-y-5">
            {[
              { n: '1', title: 'Confirmación por email',  desc: 'Te enviamos los detalles de tu compra al correo que registraste.' },
              { n: '2', title: 'Preparación del pedido',  desc: 'Nuestro equipo prepara y empaqueta tu producto con cuidado.' },
              { n: '3', title: 'Despacho',                desc: 'Tu paquete sale hacia la dirección indicada con número de seguimiento.' },
              { n: '4', title: '¡Lo recibís!',            desc: 'Disfrutá tu compra. Si tenés alguna duda, estamos para ayudarte.' },
            ].map(s => (
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 bg-nova-700 rounded-full flex items-center justify-center flex-shrink-0">
                  <span class="font-heading font-bold text-white text-xs">{s.n}</span>
                </div>
                <div>
                  <p class="font-body font-semibold text-gray-900 text-sm">{s.title}</p>
                  <p class="font-body text-gray-500 text-xs mt-0.5">{s.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Support -->
        <div class="bg-nova-50 rounded-2xl p-8 border border-nova-100">
          <h2 class="font-heading font-bold text-gray-900 text-xl mb-3">¿Necesitás ayuda?</h2>
          <p class="font-body text-gray-600 text-sm mb-6 leading-relaxed">
            Estamos disponibles para responder cualquier consulta sobre tu pedido. Contestamos rápido.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://wa.me/5491112345678"
              target="_blank"
              rel="noopener"
              class="flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-body font-semibold text-sm px-6 py-3 rounded-xl transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.116 1.524 5.843L.057 23.9l6.194-1.443A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.667-.5-5.204-1.378l-.374-.222-3.868.9.937-3.768-.245-.392A9.967 9.967 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
              WhatsApp
            </a>
            <a
              href="mailto:contacto@novashop.com.ar"
              class="flex items-center justify-center gap-2 bg-nova-700 hover:bg-nova-800 text-white font-body font-semibold text-sm px-6 py-3 rounded-xl transition-colors"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              Enviar email
            </a>
          </div>
        </div>
      </div>

      <div class="text-center">
        <a href="/" class="font-body font-semibold text-nova-700 hover:text-nova-800 text-sm transition-colors">
          ← Volver al inicio
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const status = new URLSearchParams(window.location.search).get('status');
  if (status === 'pending' || status === 'in_process') {
    document.getElementById('status-icon')!.innerHTML = `
      <div class="w-24 h-24 bg-yellow-100 rounded-full flex items-center justify-center mx-auto">
        <svg class="w-12 h-12 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>`;
    document.getElementById('status-heading')!.textContent = 'Pago en proceso';
    document.getElementById('status-body')!.textContent    = 'Tu pago está siendo procesado por MercadoPago. Te avisamos por email en cuanto se confirme.';
  }
</script>
