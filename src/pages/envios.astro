---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
---

<BaseLayout
  title="Información de Envíos — NovaShop"
  description="Enviamos a todo el país. Entrega estimada de 3 a 7 días hábiles. Conocé todos los detalles."
>
  <Header />

  <main class="pt-16">

    <!-- Hero -->
    <section class="bg-gradient-to-br from-gray-50 to-white py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="text-6xl mb-6">📦</div>
        <h1 class="font-heading font-extrabold text-gray-900 text-5xl mb-5">Envíos a todo el país</h1>
        <p class="font-body text-gray-500 text-xl max-w-2xl mx-auto">
          Hacemos llegar nuestros productos a cada rincón de la Argentina. Seguro, rápido y rastreable.
        </p>
      </div>
    </section>

    <!-- Main content -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8">

          <!-- Delivery times -->
          <div class="bg-nova-50 rounded-2xl p-8 border border-nova-100">
            <h2 class="font-heading font-bold text-gray-900 text-2xl mb-6 flex items-center gap-3">
              <svg class="w-7 h-7 text-nova-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Tiempos de entrega
            </h2>
            <div class="grid sm:grid-cols-2 gap-6">
              {[
                { zone: 'Buenos Aires y GBA', time: '2 a 4 días hábiles' },
                { zone: 'Interior de la provincia de Buenos Aires', time: '3 a 5 días hábiles' },
                { zone: 'Centro del país (Córdoba, Santa Fe, Entre Ríos)', time: '3 a 5 días hábiles' },
                { zone: 'Norte y NEA/NOA', time: '5 a 7 días hábiles' },
                { zone: 'Patagonia y zonas remotas', time: '6 a 10 días hábiles' },
                { zone: 'Zonas de difícil acceso', time: 'Consultar previamente' },
              ].map(r => (
                <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-nova-100">
                  <svg class="w-5 h-5 text-nova-700 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                  <div>
                    <p class="font-body font-semibold text-gray-900 text-sm">{r.zone}</p>
                    <p class="font-body text-nova-700 text-sm font-medium">{r.time}</p>
                  </div>
                </div>
              ))}
            </div>
            <p class="font-body text-gray-500 text-xs mt-4">
              * Los plazos son estimados y pueden variar por condiciones del correo o temporadas de alta demanda.
            </p>
          </div>

          <!-- Shipping carriers -->
          <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
            <h2 class="font-heading font-bold text-gray-900 text-2xl mb-6 flex items-center gap-3">
              <svg class="w-7 h-7 text-nova-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
              Operadores de envío
            </h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {[
                { name: 'MercadoEnvíos',     desc: 'Seguimiento en tiempo real desde tu cuenta de MercadoPago.' },
                { name: 'Correo Argentino',  desc: 'Cobertura nacional con sucursales en todo el país.' },
              ].map(carrier => (
                <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-xl border border-gray-100">
                  <div class="w-10 h-10 bg-nova-100 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-nova-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-body font-bold text-gray-900 text-sm">{carrier.name}</p>
                    <p class="font-body text-gray-500 text-xs mt-1">{carrier.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Tracking -->
          <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
            <h2 class="font-heading font-bold text-gray-900 text-2xl mb-6 flex items-center gap-3">
              <svg class="w-7 h-7 text-nova-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
              </svg>
              Rastreá tu pedido
            </h2>
            <p class="font-body text-gray-600 text-sm leading-relaxed mb-6">
              Una vez que tu pedido sea despachado, te enviaremos un email con el número de seguimiento.
              Podés rastrearlo desde:
            </p>
            <div class="space-y-3">
              {[
                'El link que te llegará por email automáticamente',
                'La sección "Mis compras" de MercadoPago',
                'La web de Correo Argentino (si aplica)',
                'Contactándonos por WhatsApp con tu número de orden',
              ].map(item => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-nova-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="font-body text-gray-700 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Costs -->
          <div class="bg-green-50 rounded-2xl p-8 border border-green-100">
            <h2 class="font-heading font-bold text-gray-900 text-2xl mb-4 flex items-center gap-3">
              <span class="text-2xl">💰</span>
              Costo de envío
            </h2>
            <p class="font-body text-gray-700 text-base leading-relaxed">
              El costo del envío se calcula automáticamente en el checkout según tu código postal.
              En muchos casos el envío puede estar incluido en el precio o tener bonificaciones especiales.
              <strong class="text-gray-900">Verificá siempre en el carrito antes de confirmar tu compra.</strong>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-heading font-bold text-gray-900 text-3xl mb-4">¿Tenés alguna duda?</h2>
        <p class="font-body text-gray-500 mb-8">Contactanos y te respondemos a la brevedad.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/5491112345678"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-body font-semibold px-6 py-3 rounded-xl transition-colors"
          >
            WhatsApp
          </a>
          <a
            href="/contacto"
            class="inline-flex items-center justify-center gap-2 bg-nova-700 hover:bg-nova-800 text-white font-body font-semibold px-6 py-3 rounded-xl transition-colors"
          >
            Ver todas las formas de contacto
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
