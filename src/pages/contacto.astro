---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
---

<BaseLayout
  title="Contacto — NovaShop"
  description="Contactanos por WhatsApp, email o Instagram. Respondemos rápido."
>
  <Header />

  <main class="pt-16">

    <!-- Hero -->
    <section class="bg-gradient-to-br from-gray-50 to-white py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-heading font-extrabold text-gray-900 text-5xl mb-5">Contacto</h1>
        <p class="font-body text-gray-500 text-xl max-w-2xl mx-auto">
          ¿Tenés una consulta, necesitás ayuda con tu pedido o querés saber más sobre nuestros productos?
          Estamos para ayudarte.
        </p>
      </div>
    </section>

    <!-- Contact cards -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="grid sm:grid-cols-3 gap-6 mb-16">

          <!-- WhatsApp -->
          <a
            href="https://wa.me/5491112345678"
            target="_blank"
            rel="noopener"
            class="group flex flex-col items-center text-center p-8 rounded-2xl border border-gray-100 hover:border-green-200 hover:bg-green-50 shadow-sm hover:shadow-md transition-all duration-200"
          >
            <div class="w-16 h-16 bg-green-50 group-hover:bg-green-100 rounded-2xl flex items-center justify-center mb-5 transition-colors">
              <svg class="w-8 h-8 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.116 1.524 5.843L.057 23.9l6.194-1.443A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.667-.5-5.204-1.378l-.374-.222-3.868.9.937-3.768-.245-.392A9.967 9.967 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
            </div>
            <h3 class="font-heading font-bold text-gray-900 text-xl mb-2">WhatsApp</h3>
            <p class="font-body text-gray-500 text-sm mb-4 leading-relaxed">La forma más rápida de contactarnos. Respondemos en minutos.</p>
            <p class="font-body font-bold text-green-600 text-base">+54 9 11 1234-5678</p>
            <span class="mt-4 inline-flex items-center gap-1 font-body text-xs text-green-600 font-semibold group-hover:underline">
              Enviar mensaje →
            </span>
          </a>

          <!-- Email -->
          <a
            href="mailto:contacto@novashop.com.ar"
            class="group flex flex-col items-center text-center p-8 rounded-2xl border border-gray-100 hover:border-nova-200 hover:bg-nova-50 shadow-sm hover:shadow-md transition-all duration-200"
          >
            <div class="w-16 h-16 bg-nova-50 group-hover:bg-nova-100 rounded-2xl flex items-center justify-center mb-5 transition-colors">
              <svg class="w-8 h-8 text-nova-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <h3 class="font-heading font-bold text-gray-900 text-xl mb-2">Email</h3>
            <p class="font-body text-gray-500 text-sm mb-4 leading-relaxed">Para consultas detalladas. Respondemos en menos de 24 hs hábiles.</p>
            <p class="font-body font-bold text-nova-700 text-sm">contacto@novashop.com.ar</p>
            <span class="mt-4 inline-flex items-center gap-1 font-body text-xs text-nova-700 font-semibold group-hover:underline">
              Enviar email →
            </span>
          </a>

          <!-- Instagram -->
          <a
            href="https://instagram.com/novashop"
            target="_blank"
            rel="noopener"
            class="group flex flex-col items-center text-center p-8 rounded-2xl border border-gray-100 hover:border-pink-200 hover:bg-pink-50 shadow-sm hover:shadow-md transition-all duration-200"
          >
            <div class="w-16 h-16 bg-pink-50 group-hover:bg-pink-100 rounded-2xl flex items-center justify-center mb-5 transition-colors">
              <svg class="w-8 h-8 text-pink-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
            <h3 class="font-heading font-bold text-gray-900 text-xl mb-2">Instagram</h3>
            <p class="font-body text-gray-500 text-sm mb-4 leading-relaxed">Seguinos para ver novedades, promos y reseñas de clientes.</p>
            <p class="font-body font-bold text-pink-600 text-base">@novashop</p>
            <span class="mt-4 inline-flex items-center gap-1 font-body text-xs text-pink-600 font-semibold group-hover:underline">
              Ir al perfil →
            </span>
          </a>
        </div>

        <!-- Hours & FAQ -->
        <div class="grid md:grid-cols-2 gap-8">

          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
            <h2 class="font-heading font-bold text-gray-900 text-xl mb-5">Horario de atención</h2>
            <div class="space-y-3">
              {[
                { day: 'Lunes a Viernes', hours: '9:00 a 18:00 hs' },
                { day: 'Sábados',         hours: '10:00 a 14:00 hs' },
                { day: 'Domingos',        hours: 'Cerrado' },
              ].map(h => (
                <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-0">
                  <span class="font-body font-medium text-gray-700 text-sm">{h.day}</span>
                  <span class={`font-body text-sm font-semibold ${h.hours === 'Cerrado' ? 'text-gray-400' : 'text-nova-700'}`}>
                    {h.hours}
                  </span>
                </div>
              ))}
            </div>
            <p class="font-body text-gray-500 text-xs mt-4">
              Fuera del horario comercial podés dejarnos un mensaje y te respondemos el siguiente día hábil.
            </p>
          </div>

          <div class="bg-nova-50 rounded-2xl p-8 border border-nova-100">
            <h2 class="font-heading font-bold text-gray-900 text-xl mb-5">Preguntas frecuentes</h2>
            <div class="space-y-4">
              {[
                { q: '¿Cuánto tarda el envío?',           a: 'De 3 a 7 días hábiles según tu ubicación.' },
                { q: '¿Puedo rastrear mi pedido?',         a: 'Sí, te enviamos el número de seguimiento por email.' },
                { q: '¿Qué pasa si el producto llega dañado?', a: 'Contactanos de inmediato con fotos y lo resolvemos.' },
                { q: '¿Aceptan cuotas?',                  a: 'Sí, con tarjeta a través de MercadoPago.' },
              ].map(faq => (
                <div>
                  <p class="font-body font-semibold text-gray-900 text-sm mb-1">{faq.q}</p>
                  <p class="font-body text-gray-600 text-xs leading-relaxed">{faq.a}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
